{"name":"confession","created":"2017-12-28T20:12:32.429Z","intents":[{"intent":"end","created":"2018-01-05T13:36:12.468Z","updated":"2018-01-05T13:36:15.788Z","examples":[{"text":"For His mercy endures forever.","created":"2018-01-05T13:36:15.788Z","updated":"2018-01-05T13:36:15.788Z"}],"description":""},{"intent":"dontHaveSins","created":"2018-01-06T12:47:05.784Z","updated":"2018-01-06T12:48:02.158Z","examples":[{"text":"I do not have any sins","created":"2018-01-06T12:47:16.692Z","updated":"2018-01-06T12:47:16.692Z"},{"text":"I dont have sins","created":"2018-01-06T12:47:22.144Z","updated":"2018-01-06T12:47:22.144Z"},{"text":"No sins","created":"2018-01-06T12:47:28.857Z","updated":"2018-01-06T12:47:28.857Z"},{"text":"I did not sin","created":"2018-01-06T12:48:02.158Z","updated":"2018-01-06T12:48:02.158Z"}],"description":""},{"intent":"regret","created":"2017-12-28T21:24:38.519Z","updated":"2017-12-28T21:24:38.519Z","examples":[{"text":"O my God, I am heartily sorry for having offended you and I detest all my sins, because I dread the loss of heaven and the pains of hell. But most of all because I have offended you, my God, who are all good and deserving of all my love. I firmly resolve with the help of your grace, to confess my sins, to do penance and to amend my life. Amen.","created":"2017-12-28T21:24:38.519Z","updated":"2017-12-28T21:24:38.519Z"}],"description":null},{"intent":"noOptions","created":"2017-12-29T13:24:25.631Z","updated":"2017-12-29T17:59:58.636Z","examples":[{"text":"no","created":"2017-12-29T13:24:34.921Z","updated":"2017-12-29T13:24:34.921Z"},{"text":"I don't have","created":"2017-12-29T13:24:41.310Z","updated":"2017-12-29T13:24:41.310Z"},{"text":"I do not have","created":"2017-12-29T13:24:46.333Z","updated":"2017-12-29T13:24:46.333Z"},{"text":"I dont have","created":"2017-12-29T13:24:51.690Z","updated":"2017-12-29T13:24:51.690Z"},{"text":"nope","created":"2017-12-29T17:58:09.498Z","updated":"2017-12-29T17:58:09.498Z"}],"description":null},{"intent":"yesOptions","created":"2017-12-29T13:16:41.893Z","updated":"2017-12-29T17:59:45.682Z","examples":[{"text":"yes","created":"2017-12-29T13:22:28.750Z","updated":"2017-12-29T13:22:28.750Z"},{"text":"I have","created":"2017-12-29T13:22:28.750Z","updated":"2017-12-29T13:22:28.750Z"},{"text":"I commited","created":"2017-12-29T13:22:28.750Z","updated":"2017-12-29T13:22:28.750Z"},{"text":"sure","created":"2017-12-29T17:58:01.724Z","updated":"2017-12-29T17:58:01.724Z"}],"description":null},{"intent":"welcome","created":"2017-12-28T21:24:38.519Z","updated":"2017-12-28T21:24:38.519Z","examples":[{"text":"In the name of the Father, and of the Son, and of the Holy Spirit.","created":"2017-12-28T21:24:38.519Z","updated":"2017-12-28T21:24:38.519Z"}],"description":null}],"updated":"2018-01-08T08:30:29.908Z","entities":[{"entity":"sys-location","values":[],"created":"2018-01-05T14:00:24.044Z","updated":"2018-01-05T14:00:24.044Z","metadata":null,"description":null},{"entity":"sys-date","values":[],"created":"2018-01-05T14:00:24.044Z","updated":"2018-01-05T14:00:24.044Z","metadata":null,"description":null},{"entity":"sins","values":[{"type":"synonyms","value":"gluttony","created":"2018-01-05T14:00:24.044Z","updated":"2018-01-08T08:30:29.908Z","metadata":null,"synonyms":["marvel","marvelled","I ate too much","I have eaten too much","I was eating so much"]},{"type":"synonyms","value":"jealousy","created":"2018-01-05T14:00:24.044Z","updated":"2018-01-06T12:56:47.071Z","metadata":null,"synonyms":["jealous","envy","green-eyed"]},{"type":"synonyms","value":"murder","created":"2018-01-05T14:00:24.044Z","updated":"2018-01-06T12:57:08.270Z","metadata":null,"synonyms":["I killed","I murdered","killed","I kill"]},{"type":"synonyms","value":"sloth","created":"2018-01-05T14:00:24.044Z","updated":"2018-01-06T12:57:36.415Z","metadata":null,"synonyms":["lazy","slothful","indolent"]},{"type":"synonyms","value":"theft","created":"2018-01-05T14:00:24.044Z","updated":"2018-01-06T12:58:51.037Z","me