"values":["Ok, tell me your sins."],"selection_policy":"sequential"}},"parent":"node_3_1515160879001","context":null,"created":"2018-01-05T14:04:09.756Z","updated":"2018-01-06T11:01:56.777Z","metadata":{},"next_step":null,"conditions":"@sys-date","description":null,"dialog_node":"node_4_1515161047649","previous_sibling":null},{"type":"standard","title":"Name unknown","output":{"text":{"values":["What's your name, my child?","This is not fun, my child, tell me your name, please."],"selection_policy":"sequential"}},"parent":"Welcome","context":null,"created":"2018-01-06T11:02:15.034Z","updated":"2018-01-06T11:07:17.750Z","metadata":{},"next_step":{"behavior":"jump_to","selector":"user_input","dialog_node":"node_3_1515160879001"},"conditions":"anything_else","description":null,"dialog_node":"node_1_1515236533544","previous_sibling":"node_3_1515160879001"},{"type":"standard","title":"Get Name","output":{"text":{"values":["I am very happy to see you there, @sys-person. When was your last confession?"],"selection_policy":"sequential"}},"parent":"Welcome","context":null,"created":"2018-01-05T14:01:21.129Z","updated":"2018-01-06T11:01:52.456Z","metadata":{},"next_step":null,"conditions":"@sys-person","description":null,"dialog_node":"node_3_1515160879001","previous_sibling":null},{"type":"event_handler","title":null,"output":{},"parent":"node_1_1514494534785","context":null,"created":"2017-12-28T21:09:11.311Z","updated":"2017-12-28T21:09:11.830Z","metadata":null,"next_step":null,"conditions":null,"event_name":"focus","description":null,"dialog_node":"handler_3_1514495351039","previous_sibling":"slot_4_1514495351049"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. Do not be jealous. Try to be happy with yourself, that's the most important thing in life. Pray the prayer of The Hail Mary. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:46:58.250Z","updated":"2017-12-29T17:22:13.397Z","metadata":{},"next_step":null,"conditions":"@sins:jealousy","description":null,"dialog_node":"node_9_1514551617715","previous_sibling":"node_8_1514551508915"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. Do not eat too much food. It's quite simple, if you feel full while eating, stop eating. Pray the Prayer Belief in God. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:49:54.070Z","updated":"2018-01-05T13:54:31.555Z","metadata":{},"next_step":null,"conditions":"@sins:gluttony","description":null,"dialog_node":"node_11_1514551793836","previous_sibling":"node_10_1514551712742"},{"type":"standard","title":"All sins confessed","output":{"text":{"values":["Now, regret your sins."],"selection_policy":"sequential"}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T13:23:32.321Z","updated":"2017-12-29T18:00:22.411Z","metadata":{},"next_step":null,"conditions":"#noOptions","description":null,"dialog_node":"node_14_1514553812075","previous_sibling":"node_13_1514553367255"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child, you have commited too many sins. But there is a chance to change for every of us. You have to pray the rosary three times, and you have to  join the monastery to change your life. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:10:27.291Z","updated":"2018-01-05T14:14:02.832Z","metadata":{},"next_step":null,"conditions":"@sins:sloth && @sins:theft && @sins:lie && @sins:anger && @sins:pride && @sins:jealousy && @sins:gluttony && @sins:murder","description":null,"dialog_node":"node_1_1514549427056","previous_sibling":"handler_3_1514495351039"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. Do not be lazy. We are created to improve ourselves, don't waste your time. Pray the prayer of The Hail Mary. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:48:32.974Z","updated":"2017-12-29T17:22:21.190Z","metadata":{},"next_step":null,"conditions":"@sins:sloth","description":null,"dialog_node":"node_10_1514551712742","previous_sibling":"node_9_1514551617715"},{"type":"standard","title":"Commited More Sins","output":{"text":{"values":["So, Tell me."],"selection_policy":"sequential"}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T13:16:07.520Z","updated":"2017-12-29T20:02:40.461Z","metadata":{},"next_step":{"behavior":"jump_to","selector":"user_input","dialog_node":"node_1_1514494534785"},"conditions":"#yesOptions","description":null,"dialog_node":"node_13_1514553367255","previous_sibling":"node_26_1515142499259"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. Do not be angry. Anger is everywhere, but we cannot allow it to come inside us. If you are angry sometimes, try to calm down. Pray the prayer of The Hail Mary. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:40:52.224Z","updated":"2018-01-05T13:53:37.834Z","metadata":{},"next_step":null,"conditions":"@sins:anger","description":null,"dialog_node":"node_6_1514551252003","previous_sibling":"node_5_1514550988588"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. Telling the truth is very important for every of us. People deserve to know the truth. Pray the prayer of the Father. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:32:52.556Z","updated":"2018-01-05T14:14:54.657Z","metadata":{},"next_step":null,"conditions":"@sins:lie","description":null,"dialog_node":"node_4_1514550772271","previous_sibling":"node_3_1514550624467"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child, you have commited many sins. But there is a chance to change for every of us. You have to pray the rosary once. Visiting church regularly can really help you to be a better person. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:30:24.700Z","updated":"2017-12-29T17:21:06.784Z","metadata":{},"next_step":null,"conditions":"@sins:sloth && @sins:theft && @sins:lie && @sins:anger && @sins:pride && @sins:jealousy && @sins:gluttony","description":null,"dialog_node":"node_3_1514550624467","previous_sibling":"node_1_1514549427056"},{"type":"standard","title":"Dont understand","output":{"text":{"values":["Sorry I think this is not related to confession. Tell me your sins."],"selection_policy":"sequential"}},"parent":"node_1_1514494534785","context":null,"created":"2018-01-04T13:52:17.063Z","updated":"2018-01-04T13:55:49.949Z","metadata":{},"next_step":{"behavior":"jump_to","selector":"user_input","dialog_node":"node_1_1514494534785"},"conditions":"anything_else","description":null,"dialog_node":"node_1_1515073936106","previous_sibling":"node_14_1514553812075"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. This sin is very very heavy. The only shrift I can give you, is that you have to join the monastery and change your life. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:52:36.760Z","updated":"2017-12-29T17:22:33.023Z","metadata":{},"next_step":null,"conditions":"@sins:murder","description":null,"dialog_node":"node_12_1514551956518","previous_sibling":"node_11_1514551793836"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. Theft is very heavy sin. You have taken something that's not yours. I hope you will return that stolen thing. Pray the prayer of The Hail Mary and the prayer of the Father. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:36:28.862Z","updated":"2017-12-29T17:21:55.383Z","metadata":{},"next_step":null,"conditions":"@sins:theft","description":null,"dialog_node":"node_5_1514550988588","previous_sibling":"node_4_1514550772271"},{"type":"slot","title":null,"output":{},"parent":"node_1_1514494534785","context":null,"created":"2017-12-28T21:09:11.801Z","updated":"2017-12-28T21:14:13.483Z","metadata":{},"variable":"$sins","next_step":null,"conditions":null,"description":null,"dialog_node":"slot_4_1514495351049","previous_sibling":"node_1_1515073936106"},{"type":"response_condition","title":null,"output":{"text":{"values":["Oh, my child. Do not be proud. Remember, ashes to ashes, dust to dust. We are all equal. Pray the prayer of the Father. Do you have any other sins?"]}},"parent":"node_1_1514494534785","context":null,"created":"2017-12-29T12:45:09.146Z","updated":"2017-12-29T17:22:08.209Z","metadata":{},"next_step":null,"conditions":"@sins:pride","description":null,"dialog_node":"node_8_1514551508915","previous_sibling":"node_6_1514551252003"},{"type":"standard","title":"Is Sin","output":{},"parent":"node_1_1514494534785","context":null,"created":"2018-01-05T08:55:01.155Z","updated":"2018-01-05T08:56:26.029Z","metadata":{},"next_step":{"behavior":"jump_to","selector":"condition","dialog_node":"node_1_1514494534785"},"conditions":"@sins","description":null,"dialog_node":"node_26_1515142499259","previous_sibling":null},{"type":"standard","title":"Anything else","output":{"text":{"values":["This is not a good way to start confession, try it again please."],"selection_policy":"sequential"}},"parent":null,"context":null,"created":"2017-12-28T20:12:32.429Z","updated":"2017-12-28T20:54:09.648Z","metadata":{},"next_step":null,"conditions":"anything_else","description":null,"dialog_node":"Anything else","previous_sibling":"Welcome"},{"type":"standard","title":"Welcome","output":{"text":{"values":["Amen. What´s your name, my child?"],"selection_policy":"sequential"}},"parent":null,"context":null,"created":"2017-12-28T20:12:32.429Z","updated":"2018-01-05T14:01:12.591Z","metadata":{},"next_step":null,"conditions":"#welcome","description":null,"dialog_node":"Welcome","previous_sibling":null}],"workspace_id":"5dd95b0b-3dcd-42f8-8ae4-f90acede5192","counterexamples":[],"learning_opt_out":false}